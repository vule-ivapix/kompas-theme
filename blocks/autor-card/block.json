{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "kompas/autor-card",
	"title": "Kompas Autor Card",
	"category": "theme",
	"description": "Prikazuje karticu autora iz CPT kompas_autor.",
